# .env.production — Template de variáveis para o deploy na Oracle Always-Free
# INSTRUÇÕES: Preencha os valores abaixo na VM e/ou nos GitHub Secrets.
#             NÃO commite este arquivo com valores reais.

# ------------------------------------------------------------------
# Backend / Flask
# ------------------------------------------------------------------
# Gere com: openssl rand -hex 32
SECRET_KEY=SUBSTITUA_PELO_SECRET_GERADO

# Origens permitidas (CORS). Use o domínio real.
ALLOWED_ORIGINS=https://assetflow.duckdns.org

# Modo produção — não altere
FLASK_DEBUG=0
ENVIRONMENT=production

# Versão do deploy (preenchida pelo CI automaticamente)
APP_RELEASE=latest

# ------------------------------------------------------------------
# Ollama / AI (internamente resolvido via docker network)
# ------------------------------------------------------------------
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b

# ------------------------------------------------------------------
# Domínio (usado pelo Caddyfile via variável de ambiente)
# ------------------------------------------------------------------
DOMAIN=assetflow.duckdns.org

# ------------------------------------------------------------------
# DuckDNS (para o cron de atualização de IP na VM)
# ------------------------------------------------------------------
# Preencha após criar conta em https://www.duckdns.org
DUCKDNS_TOKEN=SUBSTITUA_PELO_TOKEN

# ------------------------------------------------------------------
# Frontend Next.js
# ------------------------------------------------------------------
# Deixe em branco — o frontend usa o mesmo host via Caddy
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_BACKEND_URL=

# SSE direto ao backend pelo Caddy (sem passar pelo Next.js proxy)
# Já configurado no Caddyfile e em useAssetData.ts via NEXT_PUBLIC_BACKEND_URL
